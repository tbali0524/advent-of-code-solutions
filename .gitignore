# Config for git [ignore](https://git-scm.com/docs/gitignore).

# php package dependencies directory, here used only by Composer:
/vendor/

# exclude dev tool configuration local overrides
/.php-cs-fixer.php
/phpdoc.xml
/phpstan.neon

# output directory for phpDocumentor:
/docs/

# /.tools/* is excluded via a separate .gitignore file
# /.vscode/ is not excluded for convenience
